DATABASE_URL=postgresql://user:password@localhost:5432/cooperebr
DIRECT_URL=postgresql://user:password@localhost:5432/cooperebr

JWT_SECRET=

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

PORT=3000

# E-mail SMTP (envio)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=contato@cooperebr.com
EMAIL_PASS=sua-senha-de-app-aqui
EMAIL_FROM='CoopereBR <contato@cooperebr.com>'

# E-mail IMAP (recebimento)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=contato@cooperebr.com
IMAP_PASS=sua-senha-de-app-aqui

# Asaas — webhook token (configurar no painel Asaas e salvar em AsaasConfig.webhookToken)
ASAAS_WEBHOOK_TOKEN=seu-webhook-token-aqui

# PIX Excedente — transferência real via Asaas (false = modo simulação)
ASAAS_PIX_EXCEDENTE_ATIVO=false

# WhatsApp webhook secret (deve ser igual no whatsapp-service e no backend)
WHATSAPP_WEBHOOK_SECRET=seu-secret-aqui

# Números da equipe que recebem notificação de novos leads (separados por vírgula)
NUMEROS_EQUIPE=5527999375091,5527999642753
