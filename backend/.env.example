# ──────────────────────────────────────────────────────────────────
# CoopereBR Backend — .env.example
# Atualizado: 14/05/2026 (Fase 2G Hardening)
# PRODUÇÃO: rotacionar TODAS as chaves antes do deploy.
# ──────────────────────────────────────────────────────────────────

# ── Banco ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/cooperebr
DIRECT_URL=postgresql://user:password@localhost:5432/cooperebr

# ── Supabase Storage ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ── Autenticação ────────────────────────────────────────────────
JWT_SECRET=
# Chave secreta para criação de SUPER_ADMIN via endpoint protegido.
SUPER_ADMIN_SECRET_KEY=

# ── Servidor ────────────────────────────────────────────────────
PORT=3000
# production | development. Controla:
# - Helmet CSP enforce (production) vs reportOnly (development)
# - Asaas sandbox vs produção (lido de AsaasConfig.ambiente, não daqui)
# - Whitelist envios LGPD (development apenas)
NODE_ENV=development

# ── CORS (separados por vírgula) ───────────────────────────────
# Em produção: domínios reais (https://app.cooperebr.com.br, etc).
# Em dev: localhost:3001 (frontend Next.js).
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ── Encriptação Asaas API key ──────────────────────────────────
# Chave AES-256-GCM 32 bytes hex (64 chars) usada por asaas.service.ts
# pra encrypt/decrypt da apiKey gravada em AsaasConfig.
# Gerar com: openssl rand -hex 32
ASAAS_ENCRYPT_KEY=

# ── Asaas webhook (HMAC validation no asaas.controller.ts:128) ──
# Configurar no painel Asaas e gravar em AsaasConfig.webhookToken por tenant.
ASAAS_WEBHOOK_TOKEN=seu-webhook-token-aqui

# ── PIX Excedente (transferência real via Asaas) ───────────────
# false = modo simulação (não dispara API real Asaas).
# Não ativar em prod sem instrução explícita.
ASAAS_PIX_EXCEDENTE_ATIVO=false

# ── E-mail SMTP (envio) ─────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=contato@cooperebr.com
EMAIL_PASS=sua-senha-de-app-aqui
EMAIL_FROM='CoopereBR <contato@cooperebr.com>'

# ── E-mail IMAP (recebimento — pipeline OCR fatura concessionária) ──
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=contato@cooperebr.com
IMAP_PASS=sua-senha-de-app-aqui

# ── WhatsApp service (separado, PM2 cooperebr-whatsapp porta 3002) ──
WHATSAPP_SERVICE_URL=http://localhost:3002
# Deve ser igual no whatsapp-service e no backend.
WHATSAPP_WEBHOOK_SECRET=seu-secret-aqui

# Números equipe que recebem notificação de novos leads (separados por vírgula).
NUMEROS_EQUIPE=5527999375091,5527999642753

# ── Sprint 5 — bloqueio modelos COMPENSADOS/DINAMICO ───────────
# true (default): só FIXO_MENSAL aceito em runtime. false: libera engines
# bloqueadas (precondição Sub-Fase B AMAGES + mitigação D-46.SEED).
BLOQUEIO_MODELOS_NAO_FIXO=true

# ── Anthropic Claude (OCR + CoopereAI bot) ─────────────────────
ANTHROPIC_API_KEY=
# Modelo do CoopereAI (default: claude-haiku-4-5-20251001)
COOPEREAI_MODEL=claude-haiku-4-5-20251001
COOPEREAI_MAX_TOKENS=512
