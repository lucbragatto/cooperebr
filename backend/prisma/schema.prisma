generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id            String        @id @default(cuid())
  nome          String
  email         String        @unique
  cpf           String?       @unique
  telefone      String?       @unique
  supabaseId    String?       @unique
  perfil        PerfilUsuario @default(COOPERADO)
  fotoFacialUrl String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("usuarios")
}

enum PerfilUsuario {
  SUPER_ADMIN
  ADMIN
  OPERADOR
  COOPERADO
}

model Cooperado {
  id                String            @id @default(cuid())
  nomeCompleto      String
  cpf               String            @unique
  email             String            @unique
  telefone          String?
  status            StatusCooperado   @default(PENDENTE)
  cotaKwhMensal     Decimal?          @db.Decimal(10, 2)
  percentualUsina   Decimal?          @db.Decimal(8, 4)
  documento         String?
  tipoDocumento     String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  ucs               Uc[]
  contratos         Contrato[]
  ocorrencias       Ocorrencia[]
  faturasProcessadas FaturaProcessada[]

  @@map("cooperados")
}

enum StatusCooperado {
  PENDENTE
  ATIVO
  SUSPENSO
  ENCERRADO
}

model Uc {
  id                  String     @id @default(cuid())
  numero              String     @unique
  endereco            String
  cidade              String
  estado              String
  numeroUC            String?
  codigoMedidor       String?
  cep                 String?
  bairro              String?
  distribuidora       String?
  classificacao       String?
  modalidadeTarifaria String?
  tensaoNominal       String?
  tipoFornecimento    String?
  cooperadoId         String
  cooperado           Cooperado  @relation(fields: [cooperadoId], references: [id])
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  contratos           Contrato[]
  ocorrencias         Ocorrencia[]
  faturasProcessadas  FaturaProcessada[]

  @@map("ucs")
}

model Usina {
  id          String     @id @default(cuid())
  nome        String
  potenciaKwp Decimal    @db.Decimal(10, 2)
  cidade      String
  estado      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  contratos   Contrato[]

  @@map("usinas")
}

model Contrato {
  id                 String         @id @default(cuid())
  numero             String         @unique
  cooperadoId        String
  cooperado          Cooperado      @relation(fields: [cooperadoId], references: [id])
  ucId               String
  uc                 Uc             @relation(fields: [ucId], references: [id])
  usinaId            String
  usina              Usina          @relation(fields: [usinaId], references: [id])
  planoId            String?
  plano              Plano?         @relation(fields: [planoId], references: [id])
  dataInicio         DateTime
  dataFim            DateTime?
  percentualDesconto Decimal        @db.Decimal(5, 2)
  status             StatusContrato @default(ATIVO)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  cobrancas          Cobranca[]

  @@map("contratos")
}

model Plano {
  id                  String         @id @default(cuid())
  nome                String
  descricao           String?
  modeloCobranca      ModeloCobranca
  descontoBase        Decimal        @db.Decimal(5, 2)
  temPromocao         Boolean        @default(false)
  descontoPromocional Decimal?       @db.Decimal(5, 2)
  mesesPromocao       Int?
  publico             Boolean        @default(true)
  ativo               Boolean        @default(true)
  tipoCampanha        TipoCampanha   @default(PADRAO)
  dataInicioVigencia  DateTime?
  dataFimVigencia     DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  contratos           Contrato[]

  @@map("planos")
}

enum ModeloCobranca {
  FIXO_MENSAL
  CREDITOS_COMPENSADOS
  CREDITOS_DINAMICO
}

enum TipoCampanha {
  PADRAO
  CAMPANHA
}

enum StatusContrato {
  ATIVO
  SUSPENSO
  ENCERRADO
}

model Cobranca {
  id                 String         @id @default(cuid())
  contratoId         String
  contrato           Contrato       @relation(fields: [contratoId], references: [id])
  mesReferencia      Int
  anoReferencia      Int
  valorBruto         Decimal        @db.Decimal(10, 2)
  percentualDesconto Decimal        @db.Decimal(5, 2)
  valorDesconto      Decimal        @db.Decimal(10, 2)
  valorLiquido       Decimal        @db.Decimal(10, 2)
  status             StatusCobranca @default(PENDENTE)
  dataVencimento     DateTime
  dataPagamento      DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("cobrancas")
}

enum StatusCobranca {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

model Ocorrencia {
  id          String               @id @default(cuid())
  cooperadoId String
  cooperado   Cooperado            @relation(fields: [cooperadoId], references: [id])
  ucId        String?
  uc          Uc?                  @relation(fields: [ucId], references: [id])
  tipo        TipoOcorrencia
  descricao   String
  status      StatusOcorrencia     @default(ABERTA)
  prioridade  PrioridadeOcorrencia
  resolucao   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("ocorrencias")
}

enum TipoOcorrencia {
  FALTA_ENERGIA
  MEDICAO_INCORRETA
  PROBLEMA_FATURA
  SOLICITACAO
  OUTROS
}

enum StatusOcorrencia {
  ABERTA
  EM_ANDAMENTO
  RESOLVIDA
  CANCELADA
}

enum PrioridadeOcorrencia {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum StatusFatura {
  PENDENTE
  APROVADA
  REJEITADA
}

model FaturaProcessada {
  id                  String       @id @default(cuid())
  cooperadoId         String
  cooperado           Cooperado    @relation(fields: [cooperadoId], references: [id])
  ucId                String?
  uc                  Uc?          @relation(fields: [ucId], references: [id])
  arquivoUrl          String?
  dadosExtraidos      Json
  historicoConsumo    Json
  mesesUtilizados     Int
  mesesDescartados    Int
  mediaKwhCalculada   Decimal      @db.Decimal(10, 2)
  thresholdUtilizado  Decimal      @db.Decimal(5, 2)
  status              StatusFatura @default(PENDENTE)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@map("faturas_processadas")
}

model ConfigTenant {
  id        String   @id @default(cuid())
  chave     String   @unique
  valor     String
  descricao String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("config_tenant")
}
