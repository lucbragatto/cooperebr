  recorrente   Boolean   @default(true)
  convenioId   String?
  agencia      String?
  conta        String?
  banco        String?
  dadosGateway Json?
  ativo        Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

