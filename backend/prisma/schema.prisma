model FaturaSaas {
  id              String       @id @default(cuid())
  cooperativaId   String
  cooperativa     Cooperativa  @relation(fields: [cooperativaId], references: [id])
  competencia     DateTime     // mês de referência
  valorBase       Decimal      @db.Decimal(10, 2)
  valorReceita    Decimal      @default(0) @db.Decimal(10, 2) // % sobre receita
  valorTotal      Decimal      @db.Decimal(10, 2)
  status          String       @default("PENDENTE") // PENDENTE | PAGO | VENCIDO | CANCELADO
  dataVencimento  DateTime
  dataPagamento   DateTime?
  asaasCobrancaId String?      // ID da cobrança no Asaas, se emitida
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

