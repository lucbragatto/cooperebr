// ─── Gateway de Pagamento (abstração multi-gateway) ──────────────────
// ConfigGateway: config por parceiro (cada parceiro escolhe seu gateway)
// ConfigGatewayPlataforma: config do dono da plataforma (pra cobrar FaturaSaas)
// CobrancaGateway: registro unificado de cobrança em qualquer gateway

model ConfigGateway {
  id              String      @id @default(cuid())
  cooperativaId   String
  cooperativa     Cooperativa @relation(fields: [cooperativaId], references: [id])
