generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cooperativa {
  id                        String                            @id @default(cuid())
  nome                      String
  cnpj                      String                            @unique
  email                     String?
  telefone                  String?
  endereco                  String?
  numero                    String?
  bairro                    String?
  cidade                    String?
  estado                    String?
  cep                       String?
  ativo                     Boolean                           @default(true)
  tipoParceiro              String                            @default("COOPERATIVA") // COOPERATIVA | CONSORCIO | ASSOCIACAO | CONDOMINIO
  tiposOperacao             String[]                          @default([]) // USINA_PROPRIA | CONDOMINIO | EMPRESA | CARREGADOR_VEICULAR
  // Multa e juros
  multaAtraso               Decimal                           @default(2.0) @db.Decimal(5, 2)
  jurosDiarios              Decimal                           @default(0.033) @db.Decimal(5, 3)
  diasCarencia              Int                               @default(3)
  intervaloMinCobrancaHoras Int                               @default(24)
  // SaaS
  planoSaasId               String?
  planoSaas                 PlanoSaas?                        @relation(fields: [planoSaasId], references: [id])
  diaVencimentoSaas         Int                               @default(10)
  statusSaas                String                            @default("ATIVO") // ATIVO | INADIMPLENTE | SUSPENSO | TRIAL
  // ── Módulos ativos (cache do plano) ──
  modulosAtivos             String[]                          @default([])
  modalidadesAtivas         Json                              @default("{}")
  createdAt                 DateTime                          @default(now())
  updatedAt                 DateTime                          @updatedAt
  configuracoesCobranca     ConfiguracaoCobranca[]
  usinas                    Usina[]                           @relation("CooperativaUsinas")
  configGateways            ConfigGateway[]
  asaasConfig               AsaasConfig?
  faturasSaas               FaturaSaas[]
  modelosDocumento          ModeloDocumento[]
  configIndicacao           ConfigIndicacao?
  indicacoes                Indicacao[]
  usuarios                  Usuario[]
  cooperados                Cooperado[]
  configuracoesNotificacao  ConfiguracaoNotificacaoCobranca[]
  contratos                 Contrato[]                        @relation("ContratoCooperativa")
  administradoras           Administradora[]
  condominios               Condominio[]
  configClubeVantagens      ConfigClubeVantagens?
  transferencias            TransferenciaPix[]
  migracoesUsina            MigracaoUsina[]
  // ── CooperToken ──
  cooperTokenLedger         CooperTokenLedger[]
  configCooperToken         ConfigCooperToken?
  cooperTokenSaldoParceiro  CooperTokenSaldoParceiro?
  convitesIndicacao         ConviteIndicacao[]
  ofertasClube              OfertaClube[]
  contasAPagar              ContaAPagar[]
  historicosStatusCooperado HistoricoStatusCooperado[]
  bandeirasTarifarias       BandeiraTarifaria[]
  politicaBandeira          PoliticaBandeira                  @default(DECIDIR_MENSAL)
  /// @deprecated Substituído por politicaBandeira. Remover no Sprint 6 após eliminar engine órfã calcularCobrancaMensal.
  bandeiraAtiva             Boolean                           @default(false)
  bandeiraSincronizacaoAuto Boolean                           @default(false)

  @@map("cooperativas")
}

model Usuario {
  id               String            @id @default(cuid())
  nome             String
  email            String            @unique
  cpf              String?           @unique
  telefone         String?           @unique
  supabaseId       String?           @unique
  perfil           PerfilUsuario     @default(COOPERADO)
  ativo            Boolean           @default(true)
  fotoFacialUrl    String?
  resetToken       String?           @unique
  resetTokenExpiry DateTime?
  cooperativaId    String?
  cooperativa      Cooperativa?      @relation(fields: [cooperativaId], references: [id])
  administradoraId String?
  administradora   Administradora?   @relation(fields: [administradoraId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  observacoes      ObservacaoAtiva[]

  @@map("usuarios")
}

enum PerfilUsuario {
  SUPER_ADMIN
  ADMIN
  OPERADOR
  COOPERADO
  AGREGADOR
}

model Cooperado {
  id                      String                     @id @default(cuid())
  nomeCompleto            String
  cpf                     String                     @unique
  email                   String                     @unique
  telefone                String?
  status                  StatusCooperado            @default(PENDENTE)
  cotaKwhMensal           Decimal?                   @db.Decimal(10, 2)
  documento               String?
  tipoDocumento           String?
  preferenciaCobranca     String?
  tipoCooperado           TipoCooperado              @default(COM_UC)
  termoAdesaoAceito       Boolean                    @default(false)
  termoAdesaoAceitoEm     DateTime?
  usinaPropriaId          String?
  percentualRepasse       Decimal?                   @db.Decimal(5, 2)
  cooperativaId           String?
  cooperativa             Cooperativa?               @relation(fields: [cooperativaId], references: [id])
  dataInicioCreditos      DateTime?
  protocoloConcessionaria String?
  representanteLegalNome  String?
  representanteLegalCpf   String?
  representanteLegalCargo String?
  tipoPessoa              String?                    @default("PF")
  dataNascimento          DateTime?
  razaoSocial             String?
  cep                     String?
  logradouro              String?
  numero                  String?
  complemento             String?
  bairro                  String?
  cidade                  String?
  estado                  String?
  // Segurança LGPD em dev: true = não dispara notificações reais
  ambienteTeste           Boolean                    @default(false)
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  ucs                     Uc[]
  contratos               Contrato[]
  ocorrencias             Ocorrencia[]
  faturasProcessadas      FaturaProcessada[]
  documentos              DocumentoCooperado[]
  notificacoes            Notificacao[]
  propostas               PropostaCooperado[]
  listaEspera             ListaEspera[]
  prestadores             Prestador[]
  lancamentos             LancamentoCaixa[]
  contratosUso            ContratoUso[]
  convenios               ConvenioCooperado[]
  conveniosRepresentados  ContratoConvenio[]         @relation("ConveniadoConvenio")
  formaPagamento          FormaPagamentoCooperado?
  cobrancasBancarias      CobrancaBancaria[]
  usinasProprietario      Usina[]                    @relation("UsinaProprietario")
  asaasCustomer           AsaasCustomer?
  asaasCobrancas          AsaasCobranca[]
  cobrancasGateway        CobrancaGateway[]
  pixChave                String?
  pixTipo                 String?
  // Indicações MLM
  codigoIndicacao         String                     @unique @default(cuid())
  cooperadoIndicadorId    String?
  indicacoesFeitas        Indicacao[]                @relation("IndicacoesFeitas")
  indicacoesRecebidas     Indicacao[]                @relation("IndicacoesRecebidas")
  beneficiosIndicacao     BeneficioIndicacao[]
  progressaoClube         ProgressaoClube?
  unidadesCondominio      UnidadeCondominio[]
  transferencias          TransferenciaPix[]
  migracoesUsina          MigracaoUsina[]
  // Token de assinatura remota (cadastro por proxy)
  tokenAssinatura         String?
  tokenAssinaturaExp      DateTime?
  // ── CooperToken ──
  modoRemuneracao         ModoRemuneracao            @default(DESCONTO)
  /// @deprecated Substituído por modoRemuneracao. Manter por compatibilidade até Sprint 9.
  opcaoToken              String                     @default("A")
  cooperTokenLedger       CooperTokenLedger[]
  cooperTokenSaldo        CooperTokenSaldo?
  convitesEnviados        ConviteIndicacao[]         @relation("ConvitesEnviados")
  conversoesCreditoSemUc  ConversaoCreditoSemUc[]
  resgatesClubeVantagens  ResgateClubeVantagens[]
  historicoStatus         HistoricoStatusCooperado[]
  // ── Faturas Concessionária (e-mail monitor) ──
  emailFaturasAtivo       Boolean                    @default(false)
  emailFaturasAtivoEm     DateTime?
  emailFaturasObservacao  String?

  @@map("cooperados")
}

model DocumentoCooperado {
  id             String          @id @default(cuid())
  cooperadoId    String
  cooperado      Cooperado       @relation(fields: [cooperadoId], references: [id])
  tipo           TipoDocumento
  url            String
  nomeArquivo    String?
  tamanhoBytes   Int?
  status         StatusDocumento @default(PENDENTE)
  motivoRejeicao String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([cooperadoId, tipo])
  @@map("documentos_cooperados")
}

enum TipoDocumento {
  RG_FRENTE
  RG_VERSO
  CNH_FRENTE
  CNH_VERSO
  CONTRATO_SOCIAL
  OUTROS
}

enum StatusDocumento {
  PENDENTE
  APROVADO
  REPROVADO
}

enum StatusCooperado {
  PENDENTE_ASSINATURA
  PENDENTE
  PENDENTE_VALIDACAO
  PENDENTE_DOCUMENTOS
  AGUARDANDO_CONCESSIONARIA
  APROVADO
  ATIVO
  ATIVO_RECEBENDO_CREDITOS
  SUSPENSO
  ENCERRADO
}

enum TipoCooperado {
  COM_UC
  SEM_UC
  GERADOR
  CARREGADOR_VEICULAR
  USUARIO_CARREGADOR
}

// ─── Convênios ─────────────────────────────────────────────────────────────

enum TipoConvenio {
  CONDOMINIO
  ADMINISTRADORA
  ASSOCIACAO
  SINDICATO
  EMPRESA
  CLUBE
  OUTRO
}

enum StatusConvenio {
  ATIVO
  SUSPENSO
  ENCERRADO
}

enum StatusMembroConvenio {
  MEMBRO_ATIVO
  MEMBRO_SUSPENSO
  MEMBRO_DESLIGADO
}

enum EfeitoMudancaFaixa {
  SOMENTE_PROXIMAS
  INCLUIR_PENDENTES
}

model Uc {
  id                  String             @id @default(cuid())
  // Sprint 11 — Arquitetura UC: 3 campos principais
  // numero       — canônico SISGD (10 dígitos, ex: 0400702214). Identificação única dentro do sistema.
  // numeroUC     — legado da concessionária (9 dígitos, ex: 160085263). Usado em listas B2B de compensação.
  // distribuidora— concessionária responsável (obrigatório, enum). Determina formato e regras de match.
  numero              String             @unique
  endereco            String
  cidade              String
  estado              String
  numeroUC            String?
  // Número exato como aparece na fatura da concessionária (formato preservado, sem normalização).
  // Ex EDP ES atual: "0.000.512.828.054-91" (15 díg + DV com pontuação que não cabe em `numero` ou `numeroUC`).
  numeroConcessionariaOriginal String?    @db.VarChar(50)
  codigoMedidor       String?
  cep                 String?
  bairro              String?
  distribuidora       DistribuidoraEnum  @default(OUTRAS)
  classificacao       String?
  modalidadeTarifaria String?
  tensaoNominal       String?
  tipoFornecimento    String?
  cooperadoId         String
  cooperado           Cooperado          @relation(fields: [cooperadoId], references: [id])
  cooperativaId       String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  contratos           Contrato[]
  ocorrencias         Ocorrencia[]
  faturasProcessadas  FaturaProcessada[]

  @@map("ucs")
}

enum DistribuidoraEnum {
  EDP_ES
  EDP_SP
  CEMIG
  ENEL_SP
  LIGHT_RJ
  CELESC
  OUTRAS
}

model Usina {
  id                      String                    @id @default(cuid())
  nome                    String
  potenciaKwp             Decimal                   @db.Decimal(10, 2)
  capacidadeKwh           Decimal?                  @db.Decimal(15, 2)
  producaoMensalKwh       Decimal?                  @db.Decimal(15, 2)
  cidade                  String
  estado                  String
  statusHomologacao       StatusUsina               @default(CADASTRADA)
  dataHomologacao         DateTime?
  dataInicioProducao      DateTime?
  observacoes             String?
  modeloCobrancaOverride  ModeloCobranca?
  politicaBandeira        PoliticaBandeira? // null = herda da Cooperativa (cascata)
  distribuidora           String?
  cooperativaId           String?
  cooperativa             Cooperativa?              @relation("CooperativaUsinas", fields: [cooperativaId], references: [id])
  // Proprietário da usina
  proprietarioNome        String?
  proprietarioCpfCnpj     String?
  proprietarioTelefone    String?
  proprietarioEmail       String?
  proprietarioTipo        String                    @default("PF")
  proprietarioCooperadoId String?
  proprietarioCooperado   Cooperado?                @relation("UsinaProprietario", fields: [proprietarioCooperadoId], references: [id])
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  contratos               Contrato[]
  configuracoesCobranca   ConfiguracaoCobranca[]
  geracoesMensais         GeracaoMensal[]
  monitoramentoConfig     UsinaMonitoramentoConfig?
  leituras                UsinaLeitura[]
  alertas                 UsinaAlerta[]
  contratosUso            ContratoUso[]
  contasAPagar            ContaAPagar[]

  @@map("usinas")
}

enum StatusUsina {
  CADASTRADA
  AGUARDANDO_HOMOLOGACAO
  HOMOLOGADA
  EM_PRODUCAO
  SUSPENSA
}

model Contrato {
  id                       String                    @id @default(cuid())
  numero                   String                    @unique
  cooperadoId              String
  cooperado                Cooperado                 @relation(fields: [cooperadoId], references: [id])
  ucId                     String
  uc                       Uc                        @relation(fields: [ucId], references: [id])
  usinaId                  String?
  usina                    Usina?                    @relation(fields: [usinaId], references: [id])
  planoId                  String?
  plano                    Plano?                    @relation(fields: [planoId], references: [id])
  propostaId               String?
  proposta                 PropostaCooperado?        @relation(fields: [propostaId], references: [id])
  dataInicio               DateTime
  dataFim                  DateTime?
  percentualDesconto       Decimal                   @db.Decimal(5, 2)
  kwhContrato              Decimal?                  @db.Decimal(10, 5)
  percentualUsina          Decimal?                  @db.Decimal(8, 4)
  status                   StatusContrato            @default(PENDENTE_ATIVACAO)
  modeloCobrancaOverride   ModeloCobranca?
  kwhContratoAnual         Decimal?                  @db.Decimal(15, 2)
  kwhContratoMensal        Decimal?                  @db.Decimal(15, 2)
  descontoOverride         Decimal?                  @db.Decimal(5, 2)
  baseCalculoOverride      String?
  regrasAplicadas          Json?
  cooperativaId            String?
  cooperativa              Cooperativa?              @relation("ContratoCooperativa", fields: [cooperativaId], references: [id])
  ultimoReajusteEm         DateTime?
  ultimoReajusteIndice     String?
  // ── Sprint 5: campos pra refatoração da engine de cobrança ──
  valorContrato                Decimal?                  @db.Decimal(10, 2)
  tarifaContratual             Decimal?                  @db.Decimal(10, 5)
  dataUltimoReajusteTarifa     DateTime?
  // Snapshots adicionais do plano — preenchidos em aceitar()
  valorContratoPromocional     Decimal?                  @db.Decimal(10, 2)
  tarifaContratualPromocional  Decimal?                  @db.Decimal(10, 5)
  descontoPromocionalAplicado  Decimal?                  @db.Decimal(5, 2)
  mesesPromocaoAplicados       Int?
  baseCalculoAplicado          String                    @default("KWH_CHEIO")
  tipoDescontoAplicado         TipoDesconto              @default(APLICAR_SOBRE_BASE)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  cobrancas                Cobranca[]
  listaEspera              ListaEspera?
  historicoReajusteTarifa  HistoricoReajusteTarifa[]

  @@map("contratos")
}

model Plano {
  id                  String              @id @default(cuid())
  nome                String
  descricao           String?
  modeloCobranca      ModeloCobranca
  descontoBase        Decimal             @db.Decimal(5, 2)
  temPromocao         Boolean             @default(false)
  descontoPromocional Decimal?            @db.Decimal(5, 2)
  mesesPromocao       Int?
  publico             Boolean             @default(true)
  ativo               Boolean             @default(true)
  tipoCampanha        TipoCampanha        @default(PADRAO)
  dataInicioVigencia  DateTime?
  dataFimVigencia     DateTime?
  cooperativaId       String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  contratos           Contrato[]
  propostas           PropostaCooperado[]

  // ── Base de Cálculo ──
  baseCalculo         String       @default("KWH_CHEIO")
  tipoDesconto        TipoDesconto @default(APLICAR_SOBRE_BASE)
  componentesCustom   String[]     @default([])
  referenciaValor     String       @default("MEDIA_3M")
  fatorIncremento     Decimal?     @db.Decimal(5, 2)
  mostrarDiscriminado Boolean      @default(true)

  // ── CooperToken ──
  cooperTokenAtivo     Boolean  @default(false)
  tokenOpcaoCooperado  String   @default("AMBAS") // OPCAO_A | OPCAO_B | AMBAS
  tokenValorTipo       String   @default("KWH_APURADO") // FIXO | KWH_APURADO
  tokenValorFixo       Decimal? @db.Decimal(10, 4) // usado quando tokenValorTipo = FIXO
  tokenPorKwhExcedente Decimal? @db.Decimal(5, 4)
  valorTokenReais      Decimal? @db.Decimal(10, 2)
  tokenExpiracaoMeses  Int?
  tokenDescontoMaxPerc Decimal? @db.Decimal(5, 2)
  tokenSocialAtivo     Boolean  @default(false)
  tokenFlexAtivo       Boolean  @default(false)
  modoToken            String   @default("DESCONTO_DIRETO") // DESCONTO_DIRETO | FATURA_CHEIA_TOKEN

  @@map("planos")
}

enum ModeloCobranca {
  FIXO_MENSAL
  CREDITOS_COMPENSADOS
  CREDITOS_DINAMICO
}

enum PoliticaBandeira {
  APLICAR // cobra bandeira automaticamente quando vier na fatura
  NAO_APLICAR // nunca cobra bandeira do cooperado
  DECIDIR_MENSAL // admin decide manualmente por ciclo (default conservador)
}

enum TipoDesconto {
  APLICAR_SOBRE_BASE
  ABATER_DA_CHEIA
}

enum ModoRemuneracao {
  DESCONTO // Caminho tradicional — desconto direto na fatura
  CLUBE    // Caminho Clube — paga cheio, recebe tokens
}

enum TipoCampanha {
  PADRAO
  CAMPANHA
}

enum StatusContrato {
  PENDENTE_ATIVACAO
  EM_APROVACAO
  AGUARDANDO_ASSINATURA
  ASSINATURA_SOLICITADA
  APROVADO
  ATIVO
  SUSPENSO
  ENCERRADO
  LISTA_ESPERA
}

model Cobranca {
  id                       String               @id @default(cuid())
  contratoId               String
  contrato                 Contrato             @relation(fields: [contratoId], references: [id])
  mesReferencia            Int
  anoReferencia            Int
  valorBruto               Decimal              @db.Decimal(10, 2)
  percentualDesconto       Decimal              @db.Decimal(5, 2)
  valorDesconto            Decimal              @db.Decimal(10, 2)
  valorLiquido             Decimal              @db.Decimal(10, 2)
  status                   StatusCobranca       @default(PENDENTE)
  dataVencimento           DateTime
  dataPagamento            DateTime?
  valorPago                Decimal?             @db.Decimal(10, 2)
  motivoCancelamento       String?
  observacoesNegociacao    String?
  kwhEntregue              Float?
  kwhConsumido             Float?
  kwhCompensado            Float?
  kwhSaldo                 Float?
  competencia              DateTime?
  geracaoMensalId          String?
  geracaoMensal            GeracaoMensal?       @relation(fields: [geracaoMensalId], references: [id])
  descontoAplicado         Float?
  baseCalculoUsada         String?
  fonteDesconto            String?
  fonteDados               String? // FATURA_OCR | GERACAO_MANUAL | ESTIMADO
  faturaProcessadaId       String?
  cooperativaId            String?
  valorMulta               Decimal?             @db.Decimal(10, 2)
  valorJuros               Decimal?             @db.Decimal(10, 2)
  valorAtualizado          Decimal?             @db.Decimal(10, 2)
  whatsappEnviadoEm        DateTime?
  notificadoVencimento     Boolean              @default(false)
  ultimaCobrancaWhatsappEm DateTime?
  cobrancasBancarias       CobrancaBancaria[]
  asaasCobrancas           AsaasCobranca[]
  cobrancasGateway         CobrancaGateway[]
  beneficiosIndicacao      BeneficioIndicacao[]
  // ── Consumo mínimo + Bandeira tarifária ──
  kwhMinimoFaturavel       Float?               @default(0)
  valorBandeira            Decimal?             @default(0) @db.Decimal(10, 2)
  tipoBandeira             String?              @default("VERDE")
  // ── Sprint 5: snapshots pra auditoria ──
  valorTotalFatura         Decimal?             @db.Decimal(10, 2)
  consumoBruto             Float?
  tarifaApurada            Decimal?             @db.Decimal(10, 5)
  tarifaContratualAplicada Decimal?             @db.Decimal(10, 5)
  modeloCobrancaUsado      ModeloCobranca?
  bandeiraAplicada         Boolean?
  // ── CooperToken ──
  tokenDescontoQt          Decimal?             @db.Decimal(10, 4)
  tokenDescontoReais       Decimal?             @db.Decimal(10, 2)
  ledgerDebitoId           String?
  // Sprint 10: lembretes de vencimento
  lembreteD3EnviadoEm      DateTime?
  lembreteD1EnviadoEm      DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  // T6 Sprint 5: anti-duplicacao por contrato + competencia. Dupla camada:
  // guards em codigo (cobrancas.service, faturas.service) + constraint no banco.
  @@unique([contratoId, mesReferencia, anoReferencia], map: "cobranca_contrato_competencia_unique")

  @@map("cobrancas")
}

enum StatusCobranca {
  PENDENTE
  A_VENCER
  PAGO
  VENCIDO
  CANCELADO
}

model Ocorrencia {
  id            String               @id @default(cuid())
  cooperadoId   String
  cooperado     Cooperado            @relation(fields: [cooperadoId], references: [id])
  ucId          String?
  uc            Uc?                  @relation(fields: [ucId], references: [id])
  tipo          TipoOcorrencia
  descricao     String
  status        StatusOcorrencia     @default(ABERTA)
  prioridade    PrioridadeOcorrencia
  resolucao     String?
  prestadorId   String?
  prestador     Prestador?           @relation(fields: [prestadorId], references: [id])
  cooperativaId String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("ocorrencias")
}

enum TipoOcorrencia {
  FALTA_ENERGIA
  MEDICAO_INCORRETA
  PROBLEMA_FATURA
  SOLICITACAO
  FALHA_USINA
  DESLIGAMENTO
  OUTROS
}

enum StatusOcorrencia {
  ABERTA
  EM_ANDAMENTO
  RESOLVIDA
  CANCELADA
}

enum PrioridadeOcorrencia {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum StatusFatura {
  PENDENTE
  APROVADA
  REJEITADA
}

model FaturaProcessada {
  id                 String       @id @default(cuid())
  cooperadoId        String?
  cooperado          Cooperado?   @relation(fields: [cooperadoId], references: [id])
  ucId               String?
  uc                 Uc?          @relation(fields: [ucId], references: [id])
  arquivoUrl         String?
  dadosExtraidos     Json
  historicoConsumo   Json
  mesesUtilizados    Int
  mesesDescartados   Int
  mediaKwhCalculada  Decimal      @db.Decimal(10, 2)
  thresholdUtilizado Decimal      @db.Decimal(5, 2)
  status             StatusFatura @default(PENDENTE)
  cooperativaId      String?
  // ── CooperToken ──
  tokenApurado       Boolean      @default(false)
  // ── Central de Faturas ──
  analise            Json?
  mesReferencia      String?
  statusRevisao      String       @default("PENDENTE_REVISAO")
  cobrancaGeradaId   String?
  // ── Saldos e economia (P1-2) ──
  saldoKwhAnterior   Decimal?     @db.Decimal(10, 2)
  saldoKwhAtual      Decimal?     @db.Decimal(10, 2)
  validadeCreditos   DateTime?
  valorSemDesconto   Decimal?     @db.Decimal(10, 2)
