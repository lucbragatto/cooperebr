generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cooperado {
  id           String          @id @default(cuid())
  nomeCompleto String
  cpf          String          @unique
  email        String          @unique
  telefone     String?
  status       StatusCooperado @default(PENDENTE)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  ucs          Uc[]

  @@map("cooperados")
}

enum StatusCooperado {
  PENDENTE
  ATIVO
  SUSPENSO
  ENCERRADO
}

model Uc {
  id          String    @id @default(cuid())
  numero      String    @unique
  endereco    String
  cidade      String
  estado      String
  cooperadoId String
  cooperado   Cooperado @relation(fields: [cooperadoId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("ucs")
}

model Usina {
  id          String   @id @default(cuid())
  nome        String
  potenciaKwp Decimal  @db.Decimal(10, 2)
  cidade      String
  estado      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("usinas")
}
