generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cooperativa {
  id                    String                 @id @default(cuid())
  nome                  String
  cnpj                  String                 @unique
  email                 String?
  telefone              String?
  ativo                 Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  configuracoesCobranca ConfiguracaoCobranca[]

  @@map("cooperativas")
}

model Usuario {
  id            String        @id @default(cuid())
  nome          String
  email         String        @unique
  cpf           String?       @unique
  telefone      String?       @unique
  supabaseId    String?       @unique
  perfil        PerfilUsuario @default(COOPERADO)
  fotoFacialUrl String?
  cooperativaId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("usuarios")
}

enum PerfilUsuario {
  SUPER_ADMIN
  ADMIN
  OPERADOR
  COOPERADO
}

model Cooperado {
  id                  String               @id @default(cuid())
  nomeCompleto        String
  cpf                 String               @unique
  email               String               @unique
  telefone            String?
  status              StatusCooperado      @default(PENDENTE)
  cotaKwhMensal       Decimal?             @db.Decimal(10, 2)
  documento           String?
  tipoDocumento       String?
  preferenciaCobranca String?
  tipoCooperado       TipoCooperado        @default(COM_UC)
  termoAdesaoAceito   Boolean              @default(false)
  termoAdesaoAceitoEm DateTime?
  usinaPropriaId      String?
  percentualRepasse   Decimal?             @db.Decimal(5, 2)
  cooperativaId            String?
  dataInicioCreditos       DateTime?
  protocoloConcessionaria  String?
  representanteLegalNome   String?
  representanteLegalCpf    String?
  representanteLegalCargo  String?
  tipoPessoa               String?              @default("PF")
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  ucs                      Uc[]
  contratos           Contrato[]
  ocorrencias         Ocorrencia[]
  faturasProcessadas  FaturaProcessada[]
  documentos          DocumentoCooperado[]
  notificacoes        Notificacao[]
  propostas           PropostaCooperado[]
  listaEspera         ListaEspera[]

  @@map("cooperados")
}

model DocumentoCooperado {
  id             String          @id @default(cuid())
  cooperadoId    String
  cooperado      Cooperado       @relation(fields: [cooperadoId], references: [id])
  tipo           TipoDocumento
  url            String
  nomeArquivo    String?
  tamanhoBytes   Int?
  status         StatusDocumento @default(PENDENTE)
  motivoRejeicao String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([cooperadoId, tipo])
  @@map("documentos_cooperados")
}

enum TipoDocumento {
  RG_FRENTE
  RG_VERSO
  CNH_FRENTE
  CNH_VERSO
  CONTRATO_SOCIAL
  OUTROS
}

enum StatusDocumento {
  PENDENTE
  APROVADO
  REPROVADO
}

enum StatusCooperado {
  PENDENTE
  PENDENTE_VALIDACAO
  PENDENTE_DOCUMENTOS
  AGUARDANDO_CONCESSIONARIA
  APROVADO
  ATIVO
  SUSPENSO
  ENCERRADO
}

enum TipoCooperado {
  COM_UC
  SEM_UC
  GERADOR
  CARREGADOR_VEICULAR
  USUARIO_CARREGADOR
}

model Uc {
  id                  String             @id @default(cuid())
  numero              String             @unique
  endereco            String
  cidade              String
  estado              String
  numeroUC            String?
  codigoMedidor       String?
  cep                 String?
  bairro              String?
  distribuidora       String?
  classificacao       String?
  modalidadeTarifaria String?
  tensaoNominal       String?
  tipoFornecimento    String?
  cooperadoId         String
  cooperado           Cooperado          @relation(fields: [cooperadoId], references: [id])
  cooperativaId       String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  contratos           Contrato[]
  ocorrencias         Ocorrencia[]
  faturasProcessadas  FaturaProcessada[]

  @@map("ucs")
}

model Usina {
  id                     String                 @id @default(cuid())
  nome                   String
  potenciaKwp            Decimal                @db.Decimal(10, 2)
  capacidadeKwh          Decimal?               @db.Decimal(15, 2)
  producaoMensalKwh      Decimal?               @db.Decimal(15, 2)
  cidade                 String
  estado                 String
  statusHomologacao      StatusUsina            @default(CADASTRADA)
  dataHomologacao        DateTime?
  dataInicioProducao     DateTime?
  observacoes            String?
  modeloCobrancaOverride ModeloCobranca?
  distribuidora          String?
  cooperativaId          String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  contratos              Contrato[]
  configuracoesCobranca  ConfiguracaoCobranca[]
  geracoesMensais        GeracaoMensal[]

  @@map("usinas")
}

enum StatusUsina {
  CADASTRADA
  AGUARDANDO_HOMOLOGACAO
  HOMOLOGADA
  EM_PRODUCAO
  SUSPENSA
}

model Contrato {
  id                     String             @id @default(cuid())
  numero                 String             @unique
  cooperadoId            String
  cooperado              Cooperado          @relation(fields: [cooperadoId], references: [id])
  ucId                   String
  uc                     Uc                 @relation(fields: [ucId], references: [id])
  usinaId                String?
  usina                  Usina?             @relation(fields: [usinaId], references: [id])
  planoId                String?
  plano                  Plano?             @relation(fields: [planoId], references: [id])
  propostaId             String?
  proposta               PropostaCooperado? @relation(fields: [propostaId], references: [id])
  dataInicio             DateTime
  dataFim                DateTime?
  percentualDesconto     Decimal            @db.Decimal(5, 2)
  kwhContrato            Decimal?           @db.Decimal(10, 5)
  percentualUsina        Decimal?           @db.Decimal(8, 4)
  status                 StatusContrato     @default(PENDENTE_ATIVACAO)
  modeloCobrancaOverride ModeloCobranca?
  kwhContratoAnual       Decimal?           @db.Decimal(15, 2)
  kwhContratoMensal      Decimal?           @db.Decimal(15, 2)
  descontoOverride       Decimal?           @db.Decimal(5, 2)
  baseCalculoOverride    String?
  regrasAplicadas        Json?
  cooperativaId          String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  cobrancas              Cobranca[]
  listaEspera            ListaEspera?

  @@map("contratos")
}

model Plano {
  id                  String              @id @default(cuid())
  nome                String
  descricao           String?
  modeloCobranca      ModeloCobranca
  descontoBase        Decimal             @db.Decimal(5, 2)
  temPromocao         Boolean             @default(false)
  descontoPromocional Decimal?            @db.Decimal(5, 2)
  mesesPromocao       Int?
  publico             Boolean             @default(true)
  ativo               Boolean             @default(true)
  tipoCampanha        TipoCampanha        @default(PADRAO)
  dataInicioVigencia  DateTime?
  dataFimVigencia     DateTime?
  cooperativaId       String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  contratos           Contrato[]
  propostas           PropostaCooperado[]

  @@map("planos")
}

enum ModeloCobranca {
  FIXO_MENSAL
  CREDITOS_COMPENSADOS
  CREDITOS_DINAMICO
}

enum TipoCampanha {
  PADRAO
  CAMPANHA
}

enum StatusContrato {
  PENDENTE_ATIVACAO
  ATIVO
  SUSPENSO
  ENCERRADO
  LISTA_ESPERA
}

model Cobranca {
  id                 String         @id @default(cuid())
  contratoId         String
  contrato           Contrato       @relation(fields: [contratoId], references: [id])
  mesReferencia      Int
  anoReferencia      Int
  valorBruto         Decimal        @db.Decimal(10, 2)
  percentualDesconto Decimal        @db.Decimal(5, 2)
  valorDesconto      Decimal        @db.Decimal(10, 2)
  valorLiquido       Decimal        @db.Decimal(10, 2)
  status             StatusCobranca @default(PENDENTE)
  dataVencimento     DateTime
  dataPagamento      DateTime?
  valorPago          Decimal?       @db.Decimal(10, 2)
  motivoCancelamento String?
  kwhEntregue        Float?
  kwhConsumido       Float?
  kwhCompensado      Float?
  kwhSaldo           Float?
  competencia        DateTime?
  geracaoMensalId    String?
  geracaoMensal      GeracaoMensal? @relation(fields: [geracaoMensalId], references: [id])
  descontoAplicado   Float?
  baseCalculoUsada   String?
  fonteDesconto      String?
  cooperativaId      String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("cobrancas")
}

enum StatusCobranca {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

model Ocorrencia {
  id            String               @id @default(cuid())
  cooperadoId   String
  cooperado     Cooperado            @relation(fields: [cooperadoId], references: [id])
  ucId          String?
  uc            Uc?                  @relation(fields: [ucId], references: [id])
  tipo          TipoOcorrencia
  descricao     String
  status        StatusOcorrencia     @default(ABERTA)
  prioridade    PrioridadeOcorrencia
  resolucao     String?
  cooperativaId String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("ocorrencias")
}

enum TipoOcorrencia {
  FALTA_ENERGIA
  MEDICAO_INCORRETA
  PROBLEMA_FATURA
  SOLICITACAO
  OUTROS
}

enum StatusOcorrencia {
  ABERTA
  EM_ANDAMENTO
  RESOLVIDA
  CANCELADA
}

enum PrioridadeOcorrencia {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum StatusFatura {
  PENDENTE
  APROVADA
  REJEITADA
}

model FaturaProcessada {
  id                 String       @id @default(cuid())
  cooperadoId        String
  cooperado          Cooperado    @relation(fields: [cooperadoId], references: [id])
  ucId               String?
  uc                 Uc?          @relation(fields: [ucId], references: [id])
  arquivoUrl         String?
  dadosExtraidos     Json
  historicoConsumo   Json
  mesesUtilizados    Int
  mesesDescartados   Int
  mediaKwhCalculada  Decimal      @db.Decimal(10, 2)
  thresholdUtilizado Decimal      @db.Decimal(5, 2)
  status             StatusFatura @default(PENDENTE)
  cooperativaId      String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("faturas_processadas")
}

model Notificacao {
  id            String     @id @default(cuid())
  tipo          String
  titulo        String
  mensagem      String
  lida          Boolean    @default(false)
  cooperadoId   String?
  cooperado     Cooperado? @relation(fields: [cooperadoId], references: [id])
  adminId       String?
  link          String?
  cooperativaId String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("notificacoes")
}

model ConfigTenant {
  id            String   @id @default(cuid())
  chave         String   @unique
  valor         String
  descricao     String?
  cooperativaId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("config_tenant")
}

model ConfiguracaoMotor {
  id                   String   @id @default(cuid())
  fonteKwh             String   @default("MES_RECENTE")
  thresholdOutlier     Decimal  @default(1.50000) @db.Decimal(10, 5)
  acaoOutlier          String   @default("OFERECER_OPCAO")
  baseDesconto         String   @default("TARIFA_UNIT")
  descontoPadrao       Decimal  @default(20.00000) @db.Decimal(10, 5)
  descontoMinimo       Decimal  @default(15.00000) @db.Decimal(10, 5)
  descontoMaximo       Decimal  @default(30.00000) @db.Decimal(10, 5)
  acaoResultadoAcima   String   @default("AUMENTAR_DESCONTO")
  acaoResultadoAbaixo  String   @default("USAR_FATURA")
  indicesCorrecao      String[] @default(["IPCA"])
  combinacaoIndices    String   @default("MAIOR")
  limiteReajusteConces Boolean  @default(true)
  diaAplicacaoAnual    Int      @default(1)
  mesAplicacaoAnual    Int      @default(1)
  aplicacaoCorrecao    String   @default("GERAL")
  aprovarManualmente   Boolean  @default(true)
  cooperativaId        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("configuracao_motor")
}

model TarifaConcessionaria {
  id                  String              @id @default(cuid())
  concessionaria      String
  dataVigencia        DateTime
  tusdAnterior        Decimal             @db.Decimal(10, 5)
  tusdNova            Decimal             @db.Decimal(10, 5)
  teAnterior          Decimal             @db.Decimal(10, 5)
  teNova              Decimal             @db.Decimal(10, 5)
  percentualAnunciado Decimal             @db.Decimal(10, 5)
  percentualApurado   Decimal             @db.Decimal(10, 5)
  percentualAplicado  Decimal             @db.Decimal(10, 5)
  observacoes         String?
  aprovadoPor         String?
  aprovadoEm          DateTime?
  cooperativaId       String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  historico           HistoricoReajuste[]

  @@map("tarifas_concessionaria")
}

model HistoricoReajuste {
  id                  String               @id @default(cuid())
  tarifaId            String
  tarifa              TarifaConcessionaria @relation(fields: [tarifaId], references: [id])
  dataAplicacao       DateTime
  indiceUtilizado     String
  percentualIndice    Decimal              @db.Decimal(10, 5)
  percentualAnunciado Decimal              @db.Decimal(10, 5)
  percentualApurado   Decimal              @db.Decimal(10, 5)
  percentualAplicado  Decimal              @db.Decimal(10, 5)
  diferencaConc       Decimal              @db.Decimal(10, 5)
  cooperadosAfetados  Int
  valorMedioAnterior  Decimal              @db.Decimal(10, 5)
  valorMedioNovo      Decimal              @db.Decimal(10, 5)
  impactoMensalTotal  Decimal              @db.Decimal(10, 5)
  cooperativaId       String?
  createdAt           DateTime             @default(now())

  @@map("historico_reajustes")
}

model PropostaCooperado {
  id                  String     @id @default(cuid())
  cooperadoId         String
  cooperado           Cooperado  @relation(fields: [cooperadoId], references: [id])
  mesReferencia       String
  kwhMesRecente       Decimal    @db.Decimal(10, 5)
  valorMesRecente     Decimal    @db.Decimal(10, 5)
  kwhMedio12m         Decimal    @db.Decimal(10, 5)
  valorMedio12m       Decimal    @db.Decimal(10, 5)
  outlierDetectado    Boolean    @default(false)
  tusdUtilizada       Decimal    @db.Decimal(10, 5)
  teUtilizada         Decimal    @db.Decimal(10, 5)
  tarifaUnitSemTrib   Decimal    @db.Decimal(10, 5)
  kwhApuradoBase      Decimal    @db.Decimal(10, 5)
  baseUtilizada       String
  descontoPercentual  Decimal    @db.Decimal(10, 5)
  descontoAbsoluto    Decimal    @db.Decimal(10, 5)
  kwhContrato         Decimal    @db.Decimal(10, 5)
  valorCooperado      Decimal    @db.Decimal(10, 5)
  economiaAbsoluta    Decimal    @db.Decimal(10, 5)
  economiaPercentual  Decimal    @db.Decimal(10, 5)
  economiaMensal      Decimal    @db.Decimal(10, 5)
  economiaAnual       Decimal    @db.Decimal(10, 5)
  mesesEquivalentes   Decimal    @db.Decimal(10, 5)
  mediaCooperativaKwh Decimal    @db.Decimal(10, 5)
  resultadoVsMedia    Decimal    @db.Decimal(10, 5)
  opcaoEscolhida      String?
  status              String     @default("PENDENTE")
  planoId             String?
  plano               Plano?     @relation(fields: [planoId], references: [id])
  validaAte           DateTime
  cooperativaId       String?

  // Aprovação remota
  tokenAprovacao      String?    @unique
  aprovadoEm          DateTime?
  aprovadoPor         String?
  modoAprovacao       String?    // REMOTO_WHATSAPP | REMOTO_EMAIL | PRESENCIAL_ADMIN

  // Assinatura digital
  termoAdesaoAssinadoEm   DateTime?
  termoAdesaoAssinadoPor  String?
  procuracaoAssinadaEm    DateTime?
  procuracaoAssinadaPor   String?
  tokenAssinatura         String?    @unique

  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  contratos           Contrato[]

  @@map("propostas_cooperado")
}

model ModeloCobrancaConfig {
  id                  String         @id @default(cuid())
  nome                String         @unique
  descricao           String?
  tipo                ModeloCobranca
  ativo               Boolean        @default(true)
  escopo              String         @default("COOPERATIVA") // COOPERATIVA | USINA
  usinaId             String?
  descontoBase        Decimal        @db.Decimal(5, 2)
  descontoMinimo      Decimal?       @db.Decimal(5, 2)
  descontoMaximo      Decimal?       @db.Decimal(5, 2)
  temPromocao         Boolean        @default(false)
  descontoPromocional Decimal?       @db.Decimal(5, 2)
  promocaoInicio      DateTime?
  promocaoFim         DateTime?
  temProgressivo      Boolean        @default(false)
  descontoProgressivo Decimal?       @db.Decimal(5, 2)
  progressivoAteCap   Decimal?       @db.Decimal(5, 2)
  baseCalculo         String         @default("TUSD_TE") // TUSD_TE | TOTAL_FATURA | CONFIGURAVEL
  cooperativaId       String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@map("modelos_cobranca_config")
}

enum BaseCalculo {
  TUSD_TE
  TOTAL_FATURA
}

model ConfiguracaoCobranca {
  id             String      @id @default(cuid())
  cooperativaId  String
  cooperativa    Cooperativa @relation(fields: [cooperativaId], references: [id])
  usinaId        String?
  usina          Usina?      @relation(fields: [usinaId], references: [id])
  descontoPadrao Decimal     @db.Decimal(5, 2)
  descontoMin    Decimal     @db.Decimal(5, 2)
  descontoMax    Decimal     @db.Decimal(5, 2)
  baseCalculo    BaseCalculo @default(TUSD_TE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([cooperativaId, usinaId])
  @@map("configuracoes_cobranca")
}

model GeracaoMensal {
  id          String     @id @default(cuid())
  usinaId     String
  usina       Usina      @relation(fields: [usinaId], references: [id])
  competencia DateTime
  kwhGerado   Float
  fonte       String?
  observacao  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  cobrancas   Cobranca[]

  @@unique([usinaId, competencia])
  @@map("geracoes_mensais")
}

model ListaEspera {
  id            String    @id @default(cuid())
  cooperadoId   String
  cooperado     Cooperado @relation(fields: [cooperadoId], references: [id])
  contratoId    String?   @unique
  contrato      Contrato? @relation(fields: [contratoId], references: [id])
  kwhNecessario Decimal   @db.Decimal(10, 5)
  posicao       Int
  status        String    @default("AGUARDANDO")
  cooperativaId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("lista_espera")
}
