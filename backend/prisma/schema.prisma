}

model ConfiguracaoBancaria {
  id               String             @id @default(cuid())
  banco            String             // BB | SICOOB
  ambiente         String             @default("SANDBOX") // SANDBOX | PRODUCAO
  clientId         String
  clientSecret     String             // armazenar criptografado
  convenio         String?            // numero do convenio (BB)
  carteira         String?            // carteira de cobranca (BB: 17)
  agencia          String?
  conta            String?
  digitoConta      String?
  certificadoPfx   String?            // path para o .pfx (mTLS)
  certificadoSenha String?            // senha do pfx
  webhookSecret    String?            // para validar webhooks
  ativo            Boolean            @default(true)
  cooperativaId    String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  cobrancas        CobrancaBancaria[]

  @@map("configuracoes_bancarias")
}

model CobrancaBancaria {
  id                String               @id @default(cuid())
  cobrancaId        String?              // id da cobranca no sistema CoopereBR
  cobranca          Cobranca?            @relation(fields: [cobrancaId], references: [id])
  cooperadoId       String
  cooperado         Cooperado            @relation(fields: [cooperadoId], references: [id])
  configuracaoId    String
  configuracao      ConfiguracaoBancaria @relation(fields: [configuracaoId], references: [id])
  tipo              String               // BOLETO | PIX
  valor             Decimal              @db.Decimal(15, 2)
  vencimento        DateTime
  descricao         String
  nossoNumero       String?              // retornado pelo banco
  codigoBarras      String?
  linhaDigitavel    String?
  pixCopiaECola     String?
  qrCodeBase64      String?
  urlBoleto         String?
  txId              String?              // PIX txId
  status            String               @default("PENDENTE") // PENDENTE | REGISTRADO | LIQUIDADO | CANCELADO | VENCIDO
  dataPagamento     DateTime?
  valorPago         Decimal?             @db.Decimal(15, 2)
  retornoBanco      Json?                // payload completo de retorno
  webhookRecebidoEm DateTime?
  tentativas        Int                  @default(0)
  cooperativaId     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([status])
  @@index([cooperadoId])
  @@map("cobrancas_bancarias")
}

model AsaasConfig {
  id            String      @id @default(cuid())
  cooperativaId String      @unique
  cooperativa   Cooperativa @relation(fields: [cooperativaId], references: [id])
  apiKey        String      // TODO: criptografar com ASAAS_ENCRYPT_KEY
  ambiente      String      @default("SANDBOX") // SANDBOX | PRODUCAO
  webhookToken  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("asaas_configs")
}

model AsaasCustomer {
  id          String    @id @default(cuid())
  cooperadoId String    @unique
  cooperado   Cooperado @relation(fields: [cooperadoId], references: [id])
  asaasId     String    // ID do customer no Asaas (cus_xxx)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("asaas_customers")
}

model AsaasCobranca {
  id             String    @id @default(cuid())
  cobrancaId     String?   // FK para Cobranca existente
  cobranca       Cobranca? @relation(fields: [cobrancaId], references: [id])
  cooperadoId    String
  cooperado      Cooperado @relation(fields: [cooperadoId], references: [id])
  asaasId        String    // ID da cobrança no Asaas (pay_xxx)
  status         String    // PENDING, RECEIVED, CONFIRMED, OVERDUE, REFUNDED, CANCELLED
  valor          Decimal   @db.Decimal(10, 2)
  vencimento     DateTime
  linkPagamento  String?
  boletoUrl      String?
  pixQrCode      String?
  pixCopiaECola  String?
  nossoNumero    String?
  formaPagamento          String    // BOLETO | PIX | CREDIT_CARD
  ultimoWebhookEventId    String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([cooperadoId])
  @@index([status])
  @@map("asaas_cobrancas")
}

model PlanoSaas {
  id                String        @id @default(cuid())
  nome              String        // Ex: Starter, Growth, Enterprise
  descricao         String?
  taxaSetup         Decimal       @default(0) @db.Decimal(10, 2)
  mensalidadeBase   Decimal       @default(0) @db.Decimal(10, 2)
  limiteMembros     Int?          // null = ilimitado
  percentualReceita Decimal       @default(0) @db.Decimal(5, 2) // % da receita dos membros
  ativo             Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  cooperativas      Cooperativa[]

  @@map("planos_saas")
