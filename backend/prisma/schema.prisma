model ConviteIndicacao {
  id                   String        @id @default(cuid())
  cooperativaId        String
  cooperativa          Cooperativa   @relation(fields: [cooperativaId], references: [id])
  cooperadoIndicadorId String
  cooperadoIndicador   Cooperado     @relation("ConvitesEnviados", fields: [cooperadoIndicadorId], references: [id])
  nomeConvidado        String
  telefoneConvidado    String
  status               StatusConvite @default(PENDENTE)
  tentativasEnvio      Int           @default(1)
  ultimoEnvioEm        DateTime      @default(now())
  lembreteEnviadoEm    DateTime?
  cadastroConcluidoEm  DateTime?
  leadExpansaoId       String?       @unique
  leadExpansao         LeadExpansao? @relation(fields: [leadExpansaoId], references: [id])
  indicacaoId          String?       @unique
  indicacao            Indicacao?    @relation(fields: [indicacaoId], references: [id])
  // Sprint 9B: vincular convite ao convênio do remetente
  convenioId           String?
  convenio             ContratoConvenio? @relation(fields: [convenioId], references: [id])
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([cooperadoIndicadorId, telefoneConvidado])
  @@index([cooperativaId, status])
  @@index([convenioId])
  @@index([status, ultimoEnvioEm])
  @@index([telefoneConvidado])
  @@map("convites_indicacao")
}

model ConversaoCreditoSemUc {
  id            String    @id @default(cuid())
  cooperadoId   String
  cooperado     Cooperado @relation(fields: [cooperadoId], references: [id])
  cooperativaId String
  valorKwh      Decimal   @db.Decimal(10, 2)
  valorReais    Decimal   @db.Decimal(10, 2)
  tarifaUsada   Decimal   @db.Decimal(10, 4)
  status        String    @default("PENDENTE") // PENDENTE | APROVADO | PAGO | CANCELADO
  pixChave      String?
  pixNome       String?
  observacao    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([cooperadoId])
  @@index([cooperativaId, status])
  @@map("conversoes_credito_sem_uc")
}

model ConfigCooperToken {
  id                String      @id @default(cuid())
  modoGeracao       String      @default("AMBOS") // PRE_COMPRA | COTA_MENSAL | AMBOS
  modeloVida        String      @default("AMBOS") // EXPIRACAO_29D | DECAY_CONTINUO | AMBOS
  limiteTokenMensal Int?
  valorTokenReais   Decimal     @default(0.45) @db.Decimal(10, 2)
  descontoMaxPerc   Decimal     @default(30) @db.Decimal(5, 2)
  tetoCoop          Int?
  ativo             Boolean     @default(true)
  cooperativaId     String      @unique
  cooperativa       Cooperativa @relation(fields: [cooperativaId], references: [id])
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("config_cooper_token")
}

model CooperTokenSaldoParceiro {
  id                String      @id @default(cuid())
  cooperativaId     String      @unique
  cooperativa       Cooperativa @relation(fields: [cooperativaId], references: [id])
  saldoDisponivel   Decimal     @default(0) @db.Decimal(10, 4)
  totalRecebido     Decimal     @default(0) @db.Decimal(10, 4)
  totalUsadoEnergia Decimal     @default(0) @db.Decimal(10, 4)
  totalTransferido  Decimal     @default(0) @db.Decimal(10, 4)
  totalComprado     Decimal     @default(0) @db.Decimal(10, 4)
  updatedAt         DateTime    @updatedAt
  createdAt         DateTime    @default(now())

  @@map("cooper_token_saldo_parceiro")
}

model CooperTokenCompra {
  id              String    @id @default(cuid())
  cooperativaId   String
  quantidade      Decimal   @db.Decimal(10, 4)
  valorTokenReais Decimal   @db.Decimal(10, 2)
  valorTotal      Decimal   @db.Decimal(10, 2)
  formaPagamento  String // PIX | BOLETO
  status          String    @default("AGUARDANDO_PAGAMENTO") // AGUARDANDO_PAGAMENTO | PAGO | CANCELADO
  dataPagamento   DateTime?
  asaasId         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("cooper_token_compras")
}

// ── Clube de Vantagens — Ofertas e Resgates ──

model OfertaClube {
  id               String                  @id @default(cuid())
  cooperativaId    String
  cooperativa      Cooperativa             @relation(fields: [cooperativaId], references: [id])
  titulo           String
  descricao        String
  quantidadeTokens Int // tokens necessários para resgatar
  beneficio        String // descrição do que o cooperado ganha
  ativo            Boolean                 @default(true)
  validadeAte      DateTime?
  estoque          Int? // null = ilimitado
  totalResgatado   Int                     @default(0)
  emoji            String?                 @default("🎁")
  // Sprint 9B: oferta exclusiva por convênio (null = geral da cooperativa)
  convenioId       String?
  convenio         ContratoConvenio?       @relation(fields: [convenioId], references: [id])
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  resgates         ResgateClubeVantagens[]

  @@index([cooperativaId, ativo])
  @@index([convenioId])
  @@map("ofertas_clube")
}

model ResgateClubeVantagens {
  id            String      @id @default(cuid())
  cooperadoId   String
  cooperado     Cooperado   @relation(fields: [cooperadoId], references: [id])
  ofertaId      String
  oferta        OfertaClube @relation(fields: [ofertaId], references: [id])
  cooperativaId String
  tokensUsados  Int
  codigoResgate String      @unique // UUID de confirmação
  validado      Boolean     @default(false)
  validadoEm    DateTime?
  createdAt     DateTime    @default(now())

  @@index([cooperadoId])
  @@index([cooperativaId])
  @@index([codigoResgate])
  @@map("resgates_clube_vantagens")
}

// ── Histórico de Status do Cooperado (P2-1) ──

model HistoricoStatusCooperado {
  id             String       @id @default(cuid())
  cooperadoId    String
  cooperado      Cooperado    @relation(fields: [cooperadoId], references: [id])
  cooperativaId  String?
  cooperativa    Cooperativa? @relation(fields: [cooperativaId], references: [id])
  statusAnterior String
  statusNovo     String
  motivo         String?
  usuarioId      String?
  createdAt      DateTime     @default(now())

  @@index([cooperadoId])
  @@index([cooperativaId])
  @@map("historico_status_cooperado")
}

// ── Contas a Pagar (P2-2) ──

enum CategoriaContaAPagar {
  ARRENDAMENTO_USINA
  MANUTENCAO
  SALARIO
  OUTRO
}

enum StatusContaAPagar {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

model ContaAPagar {
  id             String               @id @default(cuid())
  cooperativaId  String
  cooperativa    Cooperativa          @relation(fields: [cooperativaId], references: [id])
  descricao      String
  categoria      CategoriaContaAPagar
  valor          Decimal              @db.Decimal(10, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         StatusContaAPagar    @default(PENDENTE)
  usinaId        String?
  usina          Usina?               @relation(fields: [usinaId], references: [id])
  comprovante    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([cooperativaId])
  @@index([status])
  @@index([dataVencimento])
  @@map("contas_a_pagar")
}

// ── Bandeira Tarifária (Sprint 4) ──

model BandeiraTarifaria {
  id             String      @id @default(cuid())
  cooperativaId  String
  cooperativa    Cooperativa @relation(fields: [cooperativaId], references: [id])
  tipo           String
  valorPor100Kwh Decimal     @db.Decimal(10, 4)
  dataInicio     DateTime
  dataFim        DateTime
  observacao     String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([cooperativaId, dataInicio, dataFim])
  @@map("bandeiras_tarifarias")
}
